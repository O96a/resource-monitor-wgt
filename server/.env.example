# ─── Server Identity ──────────────────────────────────────────────
SERVER_NAME=ORACLE-PROD-01
API_KEY=change-me-to-something-secure-min-32-chars
HOST=0.0.0.0
PORT=8080

# ─── Oracle Database ──────────────────────────────────────────────
# Uses python-oracledb thin mode — no Oracle Instant Client needed
ORACLE_ENABLED=true
ORACLE_USER=monitor_user
ORACLE_PASSWORD=your_oracle_password
ORACLE_DSN=localhost:1521/ORCL
# Grant these to monitor_user:
#   GRANT CREATE SESSION TO monitor_user;
#   GRANT SELECT ON V_$SESSION TO monitor_user;
#   GRANT SELECT ON V_$INSTANCE TO monitor_user;
#   GRANT SELECT ON V_$LOG_HISTORY TO monitor_user;
#   GRANT SELECT ON DBA_TABLESPACE_USAGE_METRICS TO monitor_user;
#   GRANT SELECT ON V_$PARAMETER TO monitor_user;

# ─── Alarm Thresholds (%) ─────────────────────────────────────────
ALARM_CPU_THRESHOLD=85
ALARM_RAM_THRESHOLD=90
ALARM_DISK_THRESHOLD=80
ALARM_SESSION_THRESHOLD=80
ALARM_TABLESPACE_THRESHOLD=85

# ─── FCM Push Notifications ───────────────────────────────────────
# Set FCM_ENABLED=true and supply your keys to enable push alarms
FCM_ENABLED=false
FCM_SERVER_KEY=your-fcm-legacy-server-key
FCM_DEVICE_TOKEN=android-device-fcm-token

# ─── Storage & Collection ─────────────────────────────────────────
METRICS_DB_PATH=./metrics.db
HISTORY_RETENTION_HOURS=48
COLLECTION_INTERVAL_SECONDS=30
